# =============================================================================
# Raven SaaS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in production values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django Core
# ---------------------------------------------------------------------------
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme-generate-a-real-secret-key

# Set to False in production (REQUIRED)
DEBUG=False

# Set FORCE_HTTPS=False for an http-only pilot (no TLS cert yet). Defaults
# to True so a misconfigured deploy stays safe. Flip to True once you put
# the app behind a real cert / Cloudflare / Let's Encrypt.
FORCE_HTTPS=True

# Comma-separated list of domains/IPs that can serve this app
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=raven_db
DB_USER=raven
DB_PASSWORD=changeme-use-a-strong-password
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# Redis (WebSocket channel layer + caching)
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# CORS (comma-separated origins allowed to call the API)
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ---------------------------------------------------------------------------
# Email (SMTP) - for invoice emails, notifications, password resets
# ---------------------------------------------------------------------------
# Django uses console backend in DEBUG mode, SMTP in production
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=changeme-smtp-password

# ---------------------------------------------------------------------------
# DigitalOcean Spaces (S3-compatible media storage)
# ---------------------------------------------------------------------------
# Required for production: without Spaces, attachments are written to the
# container's local disk and are lost on every redeploy.
#
# Set USE_SPACES=True and fill in the AWS_* values below.

USE_SPACES=False
# AWS_ACCESS_KEY_ID=your-spaces-access-key
# AWS_SECRET_ACCESS_KEY=your-spaces-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=nyc3
# AWS_S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
# AWS_LOCATION=media
# Default ACL is "private" + signed URLs (AWS_QUERYSTRING_AUTH=True).
# Set AWS_DEFAULT_ACL=public-read + AWS_QUERYSTRING_AUTH=False only if
# attachments should be publicly downloadable without a signed URL.
# AWS_DEFAULT_ACL=private
# AWS_QUERYSTRING_AUTH=True
# AWS_S3_CUSTOM_DOMAIN=your-bucket-name.nyc3.cdn.digitaloceanspaces.com

# ---------------------------------------------------------------------------
# Sentry (crash / error monitoring) — optional, free Developer plan works
# ---------------------------------------------------------------------------
# Leave blank to disable Sentry. Set to your project DSN to enable.
SENTRY_DSN=
# Sample rate for transaction tracing (0.0-1.0). 0.1 = 10% of requests.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Environment tag shown in Sentry (e.g. "pilot", "staging", "prod").
SENTRY_ENVIRONMENT=pilot

# ---------------------------------------------------------------------------
# CSRF Trusted Origins (required when behind reverse proxy with HTTPS)
# ---------------------------------------------------------------------------
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
